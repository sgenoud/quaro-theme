---
/**
 * Shared page shell for the theme (ported from blog.sgenoud.com's Layout).
 *
 * - Imports the theme's design tokens.
 * - Renders the full SEO/OpenGraph/Twitter head from the `site` config.
 * - Exposes named `header` / `footer` slots that fall back to the theme's
 *   default components; pass markup with `slot="header"` / `slot="footer"`
 *   to override a region.
 * - Default `<slot />` carries page content.
 *
 * Site identity comes from the `site` prop (`SiteConfig`); it defaults to
 * blog.sgenoud.com so the theme renders out of the box.
 */
import '../styles/tokens.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { DEFAULT_SITE, type SiteConfig } from '../lib/site';

interface Props {
  title?: string;
  description?: string;
  home?: boolean;
  site?: SiteConfig;
}

const {
  site = DEFAULT_SITE,
  title = site.title,
  description = site.description,
  home = false,
} = Astro.props;

const pageTitle = title === site.title ? site.title : `${title} | ${site.title}`;
const canonical = new URL(Astro.url.pathname, site.siteUrl);
const image = new URL(site.logo, site.siteUrl);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <link rel="canonical" href={canonical} />
    <link rel="alternate" type="application/rss+xml" title={site.title} href={site.social.rss ?? '/rss.xml'} />
    <meta name="description" content={description} />
    {site.googleVerification && <meta name="google-site-verification" content={site.googleVerification} />}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={image} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:creator" content={site.author} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />
  </head>
  <body>
    <div class="wrapper">
      <slot name="header"><Header title={site.title} home={home} /></slot>
      <slot />
      <slot name="footer"><Footer social={site.social} /></slot>
    </div>
  </body>
</html>

<style is:global>
  @font-face {
    font-family: 'HKGrotesk';
    font-weight: 500;
    src: url('/fonts/HKGrotesk-Regular.woff2') format('woff2');
  }

  @font-face {
    font-family: 'HKGrotesk';
    font-weight: 300;
    src: url('/fonts/HKGrotesk-Light.woff2') format('woff2');
  }

  @font-face {
    font-family: 'HKGrotesk';
    font-weight: bold;
    src: url('/fonts/HKGrotesk-Bold.woff2') format('woff2');
  }

  * {
    box-sizing: border-box;
  }

  html {
    font-family: var(--font-sans);
    font-size: var(--font-base-size);
    font-weight: var(--font-weight-normal);
    color: var(--color-text);
    background: var(--color-bg);
  }

  body {
    margin: 0;
    overflow-x: hidden;
    line-height: var(--line-height);
  }

  .wrapper {
    position: relative;
    max-width: var(--content-max-width);
    min-height: 100vh;
    margin-left: auto;
    margin-right: auto;
    padding: var(--content-padding-block) var(--content-padding-inline);
    padding-bottom: 100px;
  }

  a {
    color: var(--color-link);
  }

  a:hover {
    color: var(--color-link-hover);
  }

  p,
  ul,
  ol,
  blockquote,
  table {
    margin-top: 0;
    margin-bottom: var(--rhythm);
  }

  li {
    margin-bottom: 0.4375rem;
  }

  h1,
  h2,
  h3,
  h4,
  h5,
  h6 {
    color: var(--color-heading);
    font-weight: var(--font-weight-normal);
    line-height: 1.1;
    margin-bottom: 0.875rem;
    margin-top: var(--content-padding-block);
  }

  h1 {
    font-size: var(--font-size-h1);
    margin-top: 0;
  }

  h2 {
    font-size: var(--font-size-h2);
  }

  h3 {
    font-size: var(--font-size-h3);
  }

  h6 {
    font-size: var(--font-size-base);
    margin-top: var(--rhythm);
  }

  .home-title {
    color: var(--title-blue);
    font-size: var(--font-size-home-title);
    margin-bottom: var(--content-padding-block);
    margin-top: 0;
  }

  .home-title a,
  .site-title a,
  .post-link {
    box-shadow: none;
    color: inherit;
    text-decoration: none;
  }

  .site-title {
    color: var(--title-blue);
    font-size: var(--font-size-h3);
    margin-bottom: var(--content-padding-block);
    margin-top: 0;
  }

  small,
  .post-date {
    font-size: var(--font-size-small);
  }

  .post-date {
    display: block;
    margin-bottom: var(--rhythm);
    margin-top: -0.875rem;
  }

  img,
  video {
    height: auto;
    max-width: 100%;
  }

  article img {
    display: block;
    margin-bottom: var(--rhythm);
  }

  iframe {
    width: 100%;
    max-width: 590px;
    height: 400px;
    border-style: none;
  }

  :not(pre) > code[class*='language-'],
  :not(pre) > code {
    font-size: 0.85em;
  }

  pre {
    margin-bottom: var(--rhythm) !important;
    overflow-x: auto;
    padding: 1rem;
  }

  article :is(h2, h3, h4, h5, h6) {
    color: var(--heading-grey);
    position: relative;
  }

  article :is(h2, h3, h4, h5, h6) a.anchor {
    position: absolute;
    right: 100%;
    width: 1.2em;
    box-shadow: none;
    color: #bbb;
    opacity: 0;
    text-align: center;
    text-decoration: none;
  }

  article :is(h2, h3, h4, h5, h6):hover a.anchor,
  article :is(h2, h3, h4, h5, h6) a.anchor:focus {
    opacity: 1;
  }

  hr {
    background: var(--color-rule);
    border: 0;
    height: 1px;
    margin: var(--content-padding-block) 0 var(--rhythm);
  }
</style>
