---

<footer>
  {
    social.rss && (
      <a href={social.rss} target="_blank" rel="noopener noreferrer" aria-label="RSS feed">
        <Icon {...icons.rss} />
      </a>
    )
  }
  {
    social.mastodon && (
      <a href={social.mastodon} target="_blank" rel="me" aria-label="Mastodon">
        <Icon {...icons.mastodon} />
      </a>
    )
  }
  {
    social.github && (
      <a href={social.github} target="_blank" rel="noopener noreferrer" aria-label="GitHub">
        <Icon {...icons.github} />
      </a>
    )
  }
  {
    social.linkedIn && (
      <a href={social.linkedIn} target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
        <Icon {...icons.linkedIn} />
      </a>
    )
  }
</footer>

<style>
  footer {
    position: absolute;
    bottom: 0;
    display: flex;
    justify-content: center;
    width: calc(100% - var(--content-padding-block));
    height: 50px;
    padding-bottom: 50px;
    line-height: 50px;
  }

  a {
    color: var(--color-muted);
  }

  a:not(:first-child) {
    margin-left: 1.5em;
  }
</style>
