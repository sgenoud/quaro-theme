---
import { Image } from 'astro:assets';
import { DEFAULT_SITE } from '../lib/site';

/**
 * Author bio block: an avatar next to whatever the site puts in the slot.
 *
 * The theme ships no copy here (nothing to translate) — the site provides the
 * blurb as children, in its own language. The avatar is a site asset passed as
 * `image` (an `astro:assets` ImageMetadata); `author` is just its alt text.
 */
interface Props {
  author?: string;
  image?: ImageMetadata;
}

const { author = DEFAULT_SITE.author, image } = Astro.props;
---

<div class="bio">
  {image && <Image src={image} width={50} height={50} alt={author} />}
  <div>
    <slot />
  </div>
</div>

<style>
  .bio {
    display: flex;
    align-items: center;
    margin-bottom: calc(var(--rhythm) * 2.5);
  }

  img {
    min-width: 50px;
    margin-right: calc(var(--rhythm) * 0.5);
    margin-bottom: 0;
    border-radius: var(--radius-round);
  }
</style>
