---
import { render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import 'virtual:quaro-theme/overrides.css';
import {
  formatPostDate,
  getBlogPosts,
  getPostSlug,
  ogImageSlug,
  type BlogPost,
} from '../lib/posts';
import { SITE } from 'virtual:quaro-theme/config';

export async function getStaticPaths() {
  const posts = await getBlogPosts();

  return posts.map((post) => ({
    params: { slug: getPostSlug(post) },
    props: { post },
  }));
}

interface Props {
  post: BlogPost;
}

const { post } = Astro.props;
const { Content } = await render(post);
const ogImage = SITE.cardImages
  ? `/og/${ogImageSlug(getPostSlug(post))}.png`
  : undefined;
---

<BaseLayout
  site={SITE}
  title={post.data.title}
  description={post.data.summary}
  ogImage={ogImage}
>
  <article>
    <h1>{post.data.title}</h1>
    <p class="post-date">{formatPostDate(post.data.date, SITE.locale)}</p>
    <Content />
  </article>
</BaseLayout>
